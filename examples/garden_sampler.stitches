version: 2
patternInfo:
  name: 'Garden Sampler'
  designer: 'Eleanor Voss'
  description: 'A classic floral sampler with roses, leaves, and borders.'
  difficulty: 'Intermediate'
  estimatedHours: '45'
pattern:
  width: 50
  height: 40
  aidaColor: '#FFFFFF'
  threads:
    - dmcCode: '700'
      color: '#1E7B1E'
      name: 'Christmas Green'
      symbol: 'G'
    - dmcCode: '321'
      color: '#C11616'
      name: 'Christmas Red'
      symbol: 'R'
    - dmcCode: '726'
      color: '#F5C518'
      name: 'Topaz Light'
      symbol: 'Y'
    - dmcCode: '310'
      color: '#2C2C2C'
      name: 'Black'
      symbol: 'X'
    - dmcCode: '3713'
      color: '#FFD8D8'
      name: 'Salmon Very Light'
      symbol: 'S'
  layerItems:
    - type: layer
      id: 'layer-1'
      name: 'Main'
      visible: true
      opacity: 1.000
      stitches:
        - {type: full, x: 0, y: 0, thread: '700'}
