#!/usr/bin/env bash
# run -- project task runner for Stitches
#
# Usage:  ./run <command>
#
# Commands:
#   macos            Run the Flutter app on macOS (debug)
#   ios              Run on iOS device/simulator (debug)
#   android          Run on Android device/emulator (debug)
#   cli              Run the CLI via dart run (interpreted); pass args after --
#                      e.g.  ./run cli -- -p "╳ ▞\n▚ ╳" -o out.gif
#   build            Build the macOS release app
#   build-ipad       Build and install the iOS release app on a connected iPad
#   build-cli        Compile the CLI to a standalone binary
#   animate [--push] Generate GIF animations from test/fixtures/*.pattern into
#                      animations/. With --push: pulls first, ensures GIFs are
#                      tracked by Git LFS, then commits and pushes.
#   analyze          Run flutter analyze
#   test             Run all Dart/Flutter tests
#   test-planner     Run only the stitch planner tests
#   clean            Delete build artefacts
#   help             Show this message

set -euo pipefail

export PATH="/opt/homebrew/bin:$PATH"

FLUTTER=flutter
DART=dart
CLI_ENTRY=bin/stitches_cli.dart
CLI_BIN=build/cli/macos_arm64/bundle/bin/stitches_cli
GIT_HASH=$(git rev-parse --short HEAD 2>/dev/null || echo '')

cmd=${1:-help}
shift || true   # remaining args forwarded where needed

case "$cmd" in

  macos)
    exec $FLUTTER run -d macos --dart-define-from-file=secrets.json --dart-define=GIT_HASH="$GIT_HASH" "$@"
    ;;

  ipad)
    exec $FLUTTER run -d "00008112-0014785E0168A01E" --dart-define-from-file=secrets.json --dart-define=GIT_HASH="$GIT_HASH" "$@"
    ;;

  ios)
    exec $FLUTTER run -d ios --dart-define=GIT_HASH="$GIT_HASH" "$@"
    ;;

  android)
    exec $FLUTTER run -d 19181FDF600G2R --dart-define-from-file=secrets.json --dart-define=GIT_HASH="$GIT_HASH" --debug "$@"
    ;;

  cli)
    exec $DART run "$CLI_ENTRY" "$@"
    ;;

  build)
    $FLUTTER build macos --release --dart-define-from-file=secrets.json "$@"
    echo "Built: build/macos/Build/Products/Release/stitches.app"
    ;;

  build-ipad)
    $FLUTTER build ios --release --dart-define-from-file=secrets.json "$@"
    $FLUTTER install --release
    echo "Installed on iPad. You can now disconnect the Mac."
    ;;

  build-android)
    $FLUTTER build apk --release --dart-define-from-file=secrets.json "$@"
    $FLUTTER install --release
    echo "Installed on Android. You can now disconnect the Mac."
    ;;

  build-cli)
    mkdir -p "$(dirname "$CLI_BIN")"
    $DART compile exe "$CLI_ENTRY" -o "$CLI_BIN"
    echo "Built: $CLI_BIN"
    echo "Run with:  $CLI_BIN --help"
    ;;

  animate)
    do_push=0
    for arg in "$@"; do
      [[ "$arg" == "--push" ]] && do_push=1
    done

    if [[ $do_push -eq 1 ]]; then
      echo "Pulling latest..."
      git pull --rebase
    fi

    # Ensure Git LFS is tracking GIFs before we write any files.
    if [[ $do_push -eq 1 ]]; then
      if ! git lfs track "animations/*.gif" > /dev/null 2>&1; then
        echo "Warning: git lfs not available -- GIFs will not be LFS-tracked."
      else
        # Persist the .gitattributes entry if it changed.
        git add .gitattributes 2>/dev/null || true
      fi
    fi

    mkdir -p animations
    for pattern in test/fixtures/*.pattern; do
      name="${pattern##*/}"; name="${name%.pattern}"
      echo "Animating $name..."
      $DART run "$CLI_ENTRY" -i "$pattern" -o "animations/${name}.gif"
    done
    echo "Done -- animations saved to animations/"

    if [[ $do_push -eq 1 ]]; then
      git add animations/
      git commit -m "chore: regenerate fixture animations"
      git push
      echo "Pushed."
    fi
    ;;

  analyze)
    $FLUTTER analyze "$@"
    ;;

  test)
    $FLUTTER test "$@"
    ;;

  test-planner)
    $FLUTTER test test/stitch_planner_test.dart "$@"
    ;;

  clean)
    $FLUTTER clean
    rm -rf build/cli
    echo "Cleaned."
    ;;

  help|--help|-h)
    sed -n '2,/^$/p' "$0" | sed 's/^# \{0,1\}//'
    ;;

  *)
    echo "Unknown command: $cmd"
    echo "Run  ./run help  for usage."
    exit 1
    ;;

esac
